# ==============================================
# Zero Gravity Dev - .gitignore
# ==============================================

# --- Code Review Graph runtime (auto-generated per machine) ---
# CRG creates this folder at runtime to store the graph database.
# It rebuilds automatically — never commit it.
.code-review-graph/

# --- CRG build artifacts (inside bundled source) ---
code-review-graph/__pycache__/
code-review-graph/**/__pycache__/
code-review-graph/*.py[cod]
code-review-graph/*.egg-info/
code-review-graph/dist/
code-review-graph/build/
code-review-graph/.eggs/
code-review-graph/.venv/
code-review-graph/.pytest_cache/
code-review-graph/.mypy_cache/
code-review-graph/.coverage
code-review-graph/htmlcov/
code-review-graph/code-review-graph-vscode/dist/
code-review-graph/code-review-graph-vscode/node_modules/
code-review-graph/*.vsix
code-review-graph/*.db
code-review-graph/*.db-journal
code-review-graph/*.db-wal
code-review-graph/*.db-shm

# --- OS files ---
Thumbs.db
Desktop.ini
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# --- Editor/IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Node ---
node_modules/

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.env
.venv/
env/
venv/

# --- Logs ---
*.log
